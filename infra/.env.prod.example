# infra/.env (production) — copy to infra/.env on the VPS and fill in real
# values. NEVER commit the real .env file.
#
# Generate strong secrets locally:
#   openssl rand -base64 32   # JWT_SECRET
#   openssl rand -base64 24   # DB_PASSWORD

GH_USER=your-github-username
TAG=latest
DB_PASSWORD=change-this-to-strong-random-password
JWT_SECRET=change-this-to-32-plus-char-random-string
DOMAIN=your-coffee-shop.com
