# syntax=docker/dockerfile:1.7
# ───────── Stage 1: Builder ─────────
FROM node:20-alpine AS builder

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /repo

# Workspace manifests for cache layer
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml turbo.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/web/package.json apps/web/

RUN pnpm install --frozen-lockfile

# Source
COPY packages/shared packages/shared/
COPY apps/web apps/web/

# Build the shared package (apps/web imports from @coffee/shared/dist/*)
RUN pnpm --filter @coffee/shared build

# Build Next.js — produces apps/web/.next/standalone (server bundle) and
# apps/web/.next/static (client assets). Because next.config.ts sets
# outputFileTracingRoot = repo root, the standalone tree has the layout:
#   .next/standalone/
#   ├── apps/web/server.js  ← entrypoint
#   ├── apps/web/.next/...
#   ├── packages/shared/...
#   └── node_modules/...
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter web build

# ───────── Stage 2: Runtime ─────────
FROM node:20-alpine AS runtime

RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001 -G nodejs

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NEXT_TELEMETRY_DISABLED=1

# Standalone server bundle (already minimal: only reachable code + node_modules)
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
# Static assets (NOT included in standalone — must be copied separately)
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
